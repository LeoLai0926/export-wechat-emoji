{
  "build": {
    "beforeDevCommand": "bash tools/wechat-key-dumper/build.sh && pnpm dev",
    "beforeBuildCommand": "bash tools/wechat-key-dumper/build.sh && pnpm build",
    "withGlobalTauri": true,
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "导出微信表情包",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "path": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://*", "http://*"]
      },
      "dialog": {
        "message": true,
        "open": true
      },
      "clipboard": {
        "writeText": true
      },
      "shell": {
        "execute": true,
        "scope": [
          {
            "name": "open-dir",
            "cmd": "open",
            "args": [{ "validator": ".+" }]
          }
        ]
      },
      "fs": {
        "readDir": true,
        "exists": true,
        "createDir": true,
        "readFile": true,
        "writeFile": true,
        "copyFile": true,
        "removeFile": true,
        "scope": ["**"]
      }
    },
    "windows": [
      {
        "title": "导出微信表情包",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "me.lius.wxemoticon",
      "macOS": {
        "exceptionDomain": "wxapp.tc.qq.com,vweixinf.tc.qq.com"
      },
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": ["../tools/wechat-key-dumper/wechat_key_dumper.dylib"]
    },
    "updater": {
      "active": false,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGODVBMkUxODc2OTA1ODMKUldTREJXbUg0YUtGdnhtTW5WZnpDejRwU04wN3d3SDlsREZvelNta3o0eVJKd2ZIcFRNZGtvelIK",
      "windows": {
        "installMode": "passive",
        "installerArgs": []
      }
    }
  }
}
